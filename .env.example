# ─────────────────────────────────────────────────────────────
# LENITNES — environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000

# ── Auth ──
# 32+ char random string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Database (PostgreSQL — Supabase or Railway) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lenitnes

# ── Redis (for BullMQ job queue) ──
REDIS_URL=redis://localhost:6379

# ── Hedera (Hedera Agent Kit JS) ──
# Use a testnet operator for development.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxx
HEDERA_OPERATOR_KEY=302e0201...
HEDERA_TREASURY_ID=0.0.xxxxxx
# Single platform-wide HCS topic (or create one per monitor at runtime).
HEDERA_HCS_TOPIC_ID=0.0.xxxxxx
# Default per-check fee debited from a monitor's escrow, in HBAR.
DEFAULT_COST_PER_CHECK_HBAR=0.5

# ── TinyFish (browser-automation agent SDK) ──
TINYFISH_API_KEY=

# ── Proof Storage (Grove via Lens Protocol) ──
# Grove chain ID for immutable uploads (37111 = Lens testnet)
GROVE_CHAIN_ID=37111

# ── Kraken (per-user keys are stored encrypted in the DB; this is the
#    server-side key used to encrypt/decrypt them) ──
ENCRYPTION_KEY=change-me-32-bytes-min-aes-256-key

# ── Optional notification channels ──
# Shared secret for HMAC-signed webhook callbacks (e.g. from Kraken).
WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
SMTP_URL=

# ── x402 payment (Blocky402 facilitator) ──
X402_FACILITATOR_URL=https://blocky402.com
X402_HEDERA_NETWORK=hedera:testnet
X402_PAY_TO=0.0.xxxxxx
X402_PRICE_HBAR=0.5

# ── Frontend (Next.js public vars) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_HASHCONNECT_PROJECT_ID=
NEXT_PUBLIC_HEDERA_NETWORK=testnet
