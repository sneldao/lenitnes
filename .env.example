# ─────────────────────────────────────────────────────────────
# LENITNES — environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=8742
WEB_ORIGIN=http://localhost:3000

# ── Auth ──
# 32+ char random string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Database (PostgreSQL — Supabase or Railway) ──
DATABASE_URL=postgresql://postgres:***@localhost:5432/lenitnes

# ── Redis (for BullMQ job queue) ──
REDIS_URL=redis://localhost:6379
# Set to "true" to broadcast cache invalidations across API replicas via
# a Redis pubsub channel. Off by default — single-instance deployments
# don't need it. The local in-memory cache still works without this.
REDIS_CACHE_PUPSUB=false

# ── Agent (Day 3) ──
# MOCK_AGENT=1 returns a deterministic stub instead of calling the API.
# Leave empty (or set to 0) to use the real Virtuals endpoint.
MOCK_AGENT=1
# Conviction threshold for trades (0-100). Sub-threshold signals are
# persisted in agent_scores but produce no trade, no Telegram post,
# no outcome tracker.
CONVICTION_THRESHOLD=70
# Hard daily cap on LLM spend in USD. Circuit-breaker if exceeded.
DAILY_AGENT_BUDGET_USD=100
# Admin API key for /admin/* routes.
ADMIN_API_KEY=

# ── LLM provider (Day 3) ──
# Virtuals — OpenAI-compatible endpoint. The agent's frontier-model
# call goes through this provider. Key never committed (lives in .env,
# which is gitignored).
VIRTUALS_API_KEY=
VIRTUALS_BASE_URL=https://compute.virtuals.io/v1
# Model id sent to Virtuals. Default is Kimi K2 (good reasoning + cheap).
AGENT_MODEL=moonshotai/kimi-k2-0905
# Cost estimation per 1M tokens (input / output). Tweak per actual provider pricing.
# Used by the daily-budget circuit breaker.
AGENT_INPUT_COST_PER_1M_USD=0.60
AGENT_OUTPUT_COST_PER_1M_USD=2.50

# ── Treasury (Day 5) ──
# Day 5: every signal-derived trade runs through one system wallet
# per chain. Default chain is Arbitrum Sepolia (where signals are
# recorded). Mode defaults to 'paper' so the dev loop doesn't
# require a funded testnet wallet.
TREASURY_PRIVATE_KEY=
TREASURY_DEFAULT_CHAIN=arbitrum
TREASURY_MODE=paper
TREASURY_DEFAULT_AMOUNT=0.01
TREASURY_SLIPPAGE_BPS=50
# Day 5: tokenIn is the quote (USDC by default) and tokenOut is
# the underlying asset. Addresses are placeholders for the MVP —
# the live path requires real testnet token addresses. Override
# per chain in env (TREASURY_ARBITRUM_TOKEN_OUT etc.) when
# deploying with funded wallets.
TREASURY_DEFAULT_TOKEN_IN=0xUSDC_PLACEHOLDER

# ── Optional notification channels ──
# Shared secret for HMAC-signed webhook callbacks (e.g. from Kraken).
WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLIC_CHANNEL_ID=

# ── Frontend (Next.js public vars) ──
# Leave empty in production for same-origin relative URLs.
# Set to http://localhost:8742 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8742
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# ── EVM (Arbitrum Sepolia + Robinhood Chain + BSC) ──
# Deployer wallet key (used by `forge script script/Deploy.s.sol`).
# Same value as TREASURY_PRIVATE_KEY — the deployer wallet funds the
# contracts and signs the first trades. TREASURY_PRIVATE_KEY is what
# the api reads at runtime; EVM_PRIVATE_KEY is what the forge script
# reads (Deploy.s.sol does `vm.envUint("EVM_PRIVATE_KEY")`).
EVM_PRIVATE_KEY=
# System wallet key (Day 5 pivot). Replaces the per-user
# EVM_PRIVATE_KEY from before the pivot.
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
# Deployed contract addresses — filled in by hand after running
# `forge script script/Deploy.s.sol --broadcast` per DEPLOYMENT.md
# Step 4a (Arbitrum) / Step 4b (BSC).
ARB_SIGNAL_REGISTRY_ADDRESS=
ARB_TRADE_EXECUTOR_ADDRESS=
RH_SIGNAL_REGISTRY_ADDRESS=
RH_TRADE_EXECUTOR_ADDRESS=
ROBINHOOD_SWAP_ROUTER=

# ── BNB Smart Chain (BSC testnet, for BNB Hack June 22-28) ──
BNB_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
# PancakeSwap V2 router on BSC testnet (fixed).
BNB_SWAP_ROUTER=0xD99D1C33f9fC3444f8101754aBC46B524bA2C6BD
# Deployed contract addresses — run forge deploy against BSC testnet:
#   forge script script/Deploy.s.sol --rpc-url $BNB_RPC_URL --broadcast
# Requires BSC testnet BNB in the deployer wallet (faucet: https://testnet.bnbchain.org/faucet-smart).
BNB_SIGNAL_REGISTRY_ADDRESS=
BNB_TRADE_EXECUTOR_ADDRESS=
# BEP-20 USDC on BSC testnet (fill in after confirming via forge deploy or
# checking the BSC testnet USDC deployment).
BNB_DEFAULT_TOKEN_IN=

# ── Trust Wallet Agent Kit (TWAK — self-custody signing for BSC) ──
# Get API credentials at https://portal.trustwallet.com/dashboard/apps
# Enable with TWAK_ENABLED=true. When enabled, BSC live trades use
# TWAK swap instead of direct ethers.Wallet signing.
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
TWAK_ENABLED=false

# ── CoinMarketCap Pro API (market data enrichment for agent) ──
# Get API key at https://pro.coinmarketcap.com
# When configured, the agent receives live global metrics, Fear & Greed
# index, and asset-specific quotes alongside detector classifications.
CMC_API_KEY=

# ── x402 pay-per-request (CMC data via USDC on Base) ──
# When X402_ENABLED=true and X402_PRIVATE_KEY is set, CMC data fetches
# use the x402 protocol instead of the API key. The wallet needs USDC
# on Base (chain 8453). Costs $0.01 per request.
# This unlocks the 10-point x402 component in the TWAK special prize.
X402_ENABLED=false
X402_PRIVATE_KEY=

# GITHUB_TOKEN used for commit enrichment + the /backtest/replay
# endpoint. Optional — the demo seed works without it.
GITHUB_TOKEN=
