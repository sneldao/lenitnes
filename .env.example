# ─────────────────────────────────────────────────────────────
# LENITNES — environment configuration (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
API_PORT=8742
WEB_ORIGIN=http://localhost:3000

# ── Auth ──
# 32+ char random string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Database (PostgreSQL — Supabase or Railway) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lenitnes

# ── Redis (for BullMQ job queue) ──
REDIS_URL=redis://localhost:6379
# Set to "true" to broadcast cache invalidations across API replicas via
# a Redis pubsub channel. Off by default — single-instance deployments
# don't need it. The local in-memory cache still works without this.
REDIS_CACHE_PUPSUB=false

# ── Hedera (Hedera Agent Kit JS) ──
# Use a testnet operator for development.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxx
HEDERA_OPERATOR_KEY=302e0201...
HEDERA_TREASURY_ID=0.0.xxxxxx
# Single platform-wide HCS topic (or create one per monitor at runtime).
HEDERA_HCS_TOPIC_ID=0.0.xxxxxx

# ── TinyFish (browser-automation agent SDK) ──
TINYFISH_API_KEY=

# ── Proof Storage (Grove via Lens Protocol) ──
# Grove chain ID for immutable uploads (37111 = Lens testnet)
GROVE_CHAIN_ID=37111

# ── ENCRYPTION_KEY ──
# Used for any future at-rest encryption (e.g. treasury key material
# before KMS rollout). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-32-bytes-min-aes-256-key

# ── Optional notification channels ──
# Shared secret for HMAC-signed webhook callbacks (e.g. from Kraken).
WEBHOOK_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLIC_CHANNEL_ID=
SMTP_URL=

# ── Agent (Day 2) ──
# Conviction threshold for trades (0-100). Sub-threshold signals are
# persisted in agent_scores but produce no trade, no Telegram post,
# no outcome tracker.
CONVICTION_THRESHOLD=70
# Hard daily cap on LLM spend in USD. Circuit-breaker if exceeded.
DAILY_AGENT_BUDGET_USD=20
# Admin API key for /admin/* routes (Day 8).
ADMIN_API_KEY=
# Treasury system wallet key (32-byte hex). Lives in .env, never logged,
# never exposed to web. v1 = single key per chain. v2 = 2-of-3 Gnosis Safe.
TREASURY_PRIVATE_KEY=

# ── Frontend (Next.js public vars) ──
# Leave empty in production for same-origin relative URLs.
# Set to http://localhost:8742 for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8742
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# ── EVM (Arbitrum Sepolia + Robinhood Chain) ──
# Private key for the deployer/signer wallet (used for contract deployment + on-chain tx).
EVM_PRIVATE_KEY=
ARBITRUM_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
ROBINHOOD_RPC_URL=https://rpc.testnet.chain.robinhood.com
# Deployed contract addresses (filled in after deployment).
ARB_SIGNAL_REGISTRY_ADDRESS=
ARB_TRADE_EXECUTOR_ADDRESS=
RH_SIGNAL_REGISTRY_ADDRESS=
RH_TRADE_EXECUTOR_ADDRESS=
ROBINHOOD_SWAP_ROUTER=
