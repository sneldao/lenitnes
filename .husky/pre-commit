# 1. Lint (and auto-fix) staged TS/TSX files.
npx lint-staged

# 2. Scan staged changes for secrets.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --redact --verbose
else
  echo "⚠️  gitleaks not installed — skipping secret scan."
  echo "    Install: https://github.com/gitleaks/gitleaks  (e.g. 'brew install gitleaks')"
fi
