{
  "name": "lenitnes",
  "version": "0.1.0",
  "private": true,
  "description": "LENITNES — proof-chained web monitoring that detects on-chain/market signals and executes trades. Hedera + TinyFish + Kraken.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@lenitnes/api & npm run dev --workspace=@lenitnes/web",
    "dev:api": "npm run dev --workspace=@lenitnes/api",
    "dev:web": "npm run dev --workspace=@lenitnes/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint \"apps/**/*.{ts,tsx}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspace=@lenitnes/api",
    "test:watch": "vitest",
    "secrets": "gitleaks git --pre-commit --staged --redact --verbose",
    "prepare": "husky",
    "deploy": "bash scripts/deploy.sh",
    "health": "bash scripts/health.sh",
    "logs": "bash scripts/logs.sh"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": "prettier --write"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/supertest": "7.2.0",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "typescript-eslint": "^8.60.1",
    "vitest": "4.1.8"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "jose": "^6.2.3",
    "node-cron": "^4.2.1",
    "pg": "^8.21.0",
    "react-is": "^19.2.7",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-x64": "^1.1.1",
    "@rolldown/binding-darwin-arm64": "^1.1.1",
    "@rolldown/binding-linux-x64-gnu": "^1.1.1",
    "@rolldown/binding-linux-arm64-gnu": "^1.1.1"
  },
  "overrides": {
    "@hashgraph/sdk": "2.80.0"
  }
}
