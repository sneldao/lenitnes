{
  "name": "lenitnes",
  "version": "0.1.0",
  "private": true,
  "description": "LENITNES — proof-chained web monitoring that detects on-chain/market signals and executes trades. Hedera + TinyFish + Kraken.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@lenitnes/api & npm run dev --workspace=@lenitnes/web",
    "dev:api": "npm run dev --workspace=@lenitnes/api",
    "dev:web": "npm run dev --workspace=@lenitnes/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint \"apps/**/*.{ts,tsx}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "secrets": "gitleaks git --pre-commit --staged --redact --verbose",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript-eslint": "^8.60.1"
  }
}
