{
  "name": "@lenitnes/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LENITNES backend — orchestration API + monitor execution loop.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "migrate:followup": "tsx src/db/migrate-followup.ts",
    "seed:demo": "tsx src/seed/demo.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@hashgraph/sdk": "2.80.0",
    "@lenitnes/types": "*",
    "@x402/axios": "^2.15.0",
    "@x402/evm": "^2.15.0",
    "bullmq": "^5.52.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "hedera-agent-kit": "^3.8.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.6.1",
    "jose": "^6.2.3",
    "node-cron": "^4.2.1",
    "openai": "^4.77.0",
    "p-limit": "^6.2.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^4.7.0",
    "viem": "^2.52.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
