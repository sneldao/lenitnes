{
  "name": "@lenitnes/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LENITNES backend — orchestration API + monitor execution loop.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@lenitnes/types": "*",
    "@x402/core": "^2.14.0",
    "@x402/express": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "@x402/hedera": "^2.13.2",
    "express-rate-limit": "^7.4.1",
    "hedera-agent-kit": "^3.8.2",
    "helmet": "^8.2.0",
    "p-limit": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
